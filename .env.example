# ===========================================================
# AI Tax Advisory System — environment variables
# Copy to .env and fill in secrets. Never commit .env.
#
# Sections:
#   [SHARED]  — owned by all 4 components (infra, gateway, CORS).
#   [COMP_*]  — owned by a single component. Prefix every key with the
#               component's COMP_<NAME>_ so teammates don't collide.
# ===========================================================

# ----------------------------------------------------------
# [SHARED] Database
# ----------------------------------------------------------
# "azure" (default) uses the shared Azure Postgres server.
# "local" uses the docker-compose Postgres from docker/docker-compose.yml.
DATABASE_MODE=azure

# Azure Database for PostgreSQL - Flexible Server (Central India)
DATABASE_HOST=tax-advisory-db.postgres.database.azure.com
DATABASE_PORT=5432
DATABASE_NAME=tax-advisory-db
DATABASE_USER=axadvisor_admin
DATABASE_PASSWORD=<ask-team-lead-for-password>
DATABASE_SSLMODE=require

# Local Postgres (used when DATABASE_MODE=local)
LOCAL_DATABASE_HOST=localhost
LOCAL_DATABASE_PORT=5432
LOCAL_DATABASE_NAME=tax_advisory
LOCAL_DATABASE_USER=tax_advisory
LOCAL_DATABASE_PASSWORD=tax_advisory

# ----------------------------------------------------------
# [SHARED] Application
# ----------------------------------------------------------
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
# JSON logs for audit sinks / aggregators (Azure Monitor, Datadog, ELK).
LOG_JSON=false

# ----------------------------------------------------------
# [SHARED] Gateway + component service discovery
# ----------------------------------------------------------
GATEWAY_PORT=8000
COMP_TRANSACTION_URL=http://localhost:8001      # Component 1
COMP_OPTIMIZATION_URL=http://localhost:8002     # Component 2
COMP_RECOMMENDATION_URL=http://localhost:8003   # Component 3
COMP_LLM_URL=http://localhost:8004              # Component 4

# ----------------------------------------------------------
# [SHARED] CORS (comma-separated) and observability
# ----------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# MLFLOW_TRACKING_URI=file:./mlruns

# ----------------------------------------------------------
# [COMP_RECOMMENDATION] Component 3 — Personalized Recommendation
# Consumed by backend/comp-personalized-recommendation/app/config.py
# ----------------------------------------------------------
COMP_RECOMMENDATION_PORT=8003
# COMP_RECOMMENDATION_RULES_PATH=models/personalized-recommendation/rules/sl_tax_2024_25.yaml
# COMP_RECOMMENDATION_ARTIFACTS_DIR=models/personalized-recommendation/artifacts
# COMP_RECOMMENDATION_DATA_DIR=data/synthetic
# COMP_RECOMMENDATION_DEFAULT_TOP_K=5
# COMP_RECOMMENDATION_DEFAULT_MC_PATHS=2000
# COMP_RECOMMENDATION_DEFAULT_HORIZON_YEARS=10
# COMP_RECOMMENDATION_W_SAVINGS=0.40
# COMP_RECOMMENDATION_W_ADOPTION=0.30
# COMP_RECOMMENDATION_W_FEASIBILITY=0.20
# COMP_RECOMMENDATION_W_RISK_PENALTY=0.10

# ----------------------------------------------------------
# [COMP_OPTIMIZATION] Component 2 — Tax Strategy Optimization (it22064486)
# Consumed by backend/comp-tax-optimization/tax_opt_b_app/config.py
# ----------------------------------------------------------
COMP_OPTIMIZATION_PORT=8002
# COMP_OPTIMIZATION_RULES_PATH=models/tax-optimization/rules/it22064486_sl_tax_mvp.yaml
# COMP_OPTIMIZATION_RULES_VERSION=it22064486_mvp_2024_25

# ----------------------------------------------------------
# [COMP_LLM] Component 4 — Language model / retrieval (comp-language-model)
# Consumed by backend/comp-language-model/app/config.py
# ----------------------------------------------------------
# Path to Phase 1b corpus_v1.jsonl for TF-IDF baseline (optional; omit for stub NLU).
# COMP_LLM_CORPUS_JSONL=data/processed/ird/corpus_v1.jsonl
# COMP_LLM_RETRIEVAL_TOP_K=8
# Phase 2 Step 4: optional benchmark JSONL to fit TF-IDF centroid intent in /api/v1/nlu/parse
# COMP_LLM_INTENT_BENCHMARK_JSONL=evaluation/benchmark_seed_template.jsonl

# ----------------------------------------------------------
# [COMP_TRANSACTION]   Component 1 — add your keys with COMP_TRANSACTION_ prefix
# ----------------------------------------------------------

# ----------------------------------------------------------
# Optional: SQLite file DB for isolated local dev (no Azure credentials needed).
# DATABASE_MODE=sqlite
# SQLITE_PATH=data/dev.db
# ----------------------------------------------------------
