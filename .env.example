# Azure Database for PostgreSQL - Flexible Server (Central India)
DATABASE_HOST=tax-advisory-db.postgres.database.azure.com
DATABASE_PORT=5432
DATABASE_NAME=tax-advisory-db
DATABASE_USER=axadvisor_admin
DATABASE_PASSWORD=<ask-team-lead-for-password>
DATABASE_SSLMODE=require

# Application settings
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
# JSON logs for audit sinks / aggregators (Azure Monitor, Datadog, ELK).
LOG_JSON=false
