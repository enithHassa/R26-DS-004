# Leave unset during Vite dev so the browser uses same-origin ``/api/...`` and Vite proxies:
#   ``/api/v1/optimization/*`` → http://127.0.0.1:8002 (comp-tax-optimization, path rewritten)
#   other ``/api/*`` → gateway (default http://127.0.0.1:8000)
# If you set a full URL here, the browser talks to that host directly (no Vite proxy).
# VITE_API_BASE_URL=http://localhost:8000
#
# Optional: override Component B URL for the dev proxy only
# VITE_DEV_OPTIMIZATION_URL=http://127.0.0.1:8002
